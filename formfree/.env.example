APP_NAME=FormFree
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.railway.app

LOG_CHANNEL=stderr
LOG_LEVEL=warning

# ─── データベース（Supabase PostgreSQL）───────────────────────
DB_CONNECTION=pgsql
DB_HOST=db.xxxx.supabase.co
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=your-supabase-db-password
DB_SSLMODE=require

# ─── Supabase Storage ────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your-service-role-key

# ─── キュー（DB方式） ─────────────────────────────────────────
QUEUE_CONNECTION=database

# ─── メール（Resend推奨） ─────────────────────────────────────
MAIL_MAILER=resend
RESEND_KEY=re_xxxx
MAIL_FROM_ADDRESS=noreply@formfree.jp
MAIL_FROM_NAME=FormFree

# ─── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
STRIPE_PRICE_STANDARD=price_xxxx
STRIPE_PRICE_PRO=price_yyyy

# ─── Python変換サービス ───────────────────────────────────────
PYTHON_CONVERTER_URL=http://python-service.railway.internal:8000
PYTHON_CONVERTER_SECRET=your-shared-secret-64-chars
